# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# ─── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/disha_signature

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Seed admin (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@dishasignature.com
SEED_ADMIN_PASSWORD=disha@2025
SEED_ADMIN_NAME=Disha Admin

# ─── Cloudinary (media uploads) ───────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
